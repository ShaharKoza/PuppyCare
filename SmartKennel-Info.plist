<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- App Transport Security:
         NSAllowsLocalNetworking permits cleartext HTTP loads ONLY to
         local network addresses (.local hostnames, RFC1918 IPs).
         It is far narrower than NSAllowsArbitraryLoads, which App Store
         review penalises.  This is exactly what we need for an MJPEG
         stream from a Raspberry Pi on the same Wi-Fi. -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsLocalNetworking</key>
        <true/>
    </dict>

    <!-- Bonjour services the app advertises / browses for.
         Required since iOS 14 BEFORE the OS will resolve any *.local
         hostname or talk to a non-public IP — without this, even with
         the local-network permission granted, mDNS lookup of
         raspberrypi.local fails silently and the camera AsyncImage
         drops into the failure case. The two HTTP service types cover
         the MJPEG streamer (port 8081) and any future TLS variant. -->
    <key>NSBonjourServices</key>
    <array>
        <string>_http._tcp</string>
        <string>_https._tcp</string>
    </array>
</dict>
</plist>
